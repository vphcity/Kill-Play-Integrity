#!/system/bin/sh
[ -z "$ZIPFILE" ] && ZIPFILE="$3"
if [ -z "$ZIPFILE" ] || [ ! -f "$ZIPFILE" ]; then
    ZIPFILE=$(find /data/user/0/me.bmax.apatch/cache -name "*.zip" 2>/dev/null | head -n 1)
fi
unzip -o "$ZIPFILE" -x "META-INF/*" -d "$MODPATH"
sed -i 's/\r$//' "$MODPATH/customize.sh" 2>/dev/null
[ -f "$MODPATH/customize.sh" ] && . "$MODPATH/customize.sh"
exit 0
